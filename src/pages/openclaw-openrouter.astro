---
import ArticleShell from '../components/content/ArticleShell.astro';
import AISummary from '../components/content/AISummary.astro';
import QuickAnswer from '../components/content/QuickAnswer.astro';
import Checklist from '../components/content/Checklist.astro';
import EvidenceList from '../components/content/EvidenceList.astro';
import FailureModes from '../components/content/FailureModes.astro';
import FAQBlock from '../components/content/FAQBlock.astro';
import RelatedPages from '../components/content/RelatedPages.astro';
import RutaCta from '../components/content/RutaCta.astro';
import { publicPages } from '../data/pages';

const page = publicPages.find(p => p.slug === 'openclaw-openrouter')!;

const quickAnswerSteps = [
  'Set the OpenRouter OpenAI-compatible base URL in OpenClaw.',
  'Choose the exact model ID and confirm the provider route.',
  'Check fallback model behavior before long runs.',
  'Verify credits are loaded and watch for 401, 403 and 429 errors.',
  'Treat 404 and model unavailable responses as routing problems first.',
];

const checklistItems = [
  'Confirm the OpenRouter base URL in OpenClaw settings.',
  'Verify the OpenRouter API key is active and has available credits.',
  'Check the exact model ID and provider route before the first run.',
  'Review fallback routing for model unavailable responses.',
  'Set up request logging to capture request IDs, model IDs and token counts.',
  'Monitor for 401, 403, 404, 429 and 5xx errors in early runs.',
  'Test with a small prepaid API balance before scaling.',
];

const evidenceItems = [
  { label: 'OpenRouter dashboard', value: 'credits balance, route access and model catalog' },
  { label: 'OpenRouter /v1/models', value: 'model availability, exact IDs and pricing per model' },
  { label: 'OpenClaw config', value: 'base URL, API key and provider routing configuration' },
  { label: 'Request logs', value: 'request IDs, token counts, model IDs and retries' },
];

const failureModes = [
  {
    symptom: '401 Unauthorized on every request',
    cause: 'The API key is missing, invalid or revoked.',
    whatToDo: 'Verify the key in the OpenRouter dashboard and confirm the header or secret path is correct.',
  },
  {
    symptom: '403 Forbidden on a specific model',
    cause: 'The key is valid but the account, route or tier does not allow that model.',
    whatToDo: 'Check the model catalog, route permissions and account tier before retrying.',
  },
  {
    symptom: '404 or model unavailable response',
    cause: 'The model ID is stale, misspelled or not available on that route.',
    whatToDo: 'Confirm the exact model ID in /v1/models and test a fallback model before scaling.',
  },
  {
    symptom: '429 rate limit or timeout errors',
    cause: 'Too many concurrent requests, retry loops or provider-side throttling.',
    whatToDo: 'Reduce concurrency, add backoff and inspect rate limit headers before scaling up automation.',
  },
  {
    symptom: 'Token usage is higher than expected',
    cause: 'Large context windows, repeated tool calls, fallback retries or long completions.',
    whatToDo: 'Review request logs and token counts per call. Compare the first route with the fallback route to see which one is expensive.',
  },
];

const faqItems = [
  {
    q: 'How do I connect OpenClaw to OpenRouter?',
    a: 'Set the OpenAI-compatible base URL to https://openrouter.ai/api/v1, add your OpenRouter API key in OpenClaw configuration, and choose a model ID from the OpenRouter catalog. Confirm credits are loaded in your OpenRouter account, then run a short test session before longer agent workflows.',
  },
  {
    q: 'Why can OpenClaw token usage increase quickly?',
    a: 'OpenClaw may resend full conversation history on each turn, include file reads and tool outputs in the prompt, and retry failed requests with the same context. Each model on OpenRouter has separate input and output token pricing, so tool-heavy workflows can multiply API usage across turns.',
  },
  {
    q: 'What should I check before running OpenClaw with a paid API key?',
    a: 'Verify the base URL and API key, confirm credits are available, check that your chosen model ID is in your OpenRouter tier, and review token pricing for that model. Enable request logging, test with a small prepaid balance, check live model pricing, and review request logs and usage records before scaling.',
  },
  {
    q: 'How do credits, model routing and 401/403 errors relate?',
    a: 'OpenRouter routes requests to underlying providers based on the model ID you set in OpenClaw. Credits must be available before requests succeed. A 401 usually means a missing or invalid API key. A 403 often means the key is valid but lacks access to the requested model, or credits are insufficient for that route. Model availability can change, so confirm the model with the /v1/models endpoint before long runs.',
  },
  {
    q: 'What is an OpenAI-compatible endpoint?',
    a: 'An OpenAI-compatible endpoint means OpenClaw can send requests using the same format as the OpenAI API. The base URL is set to OpenRouter instead of OpenAI, and model IDs follow the OpenRouter catalog naming convention.',
  },
  {
    q: 'What are the security risks of using OpenClaw with OpenRouter?',
    a: 'Security risks include: chat ingress through conversation history that may be logged by the provider, file permission exposure through OpenClaw tool execution, command execution on the host system, and prompt injection through malicious user inputs. Review OpenClaw documentation and restrict file access and tool permissions appropriately.',
  },
];

const relatedLinks = [
  { label: 'OpenClaw API Key', href: '/openclaw-api-key/', desc: 'Use this for the generic key, Base URL and provider access checks.' },
  { label: 'Claude Code Token Cost', href: '/claude-code-token-cost/', desc: 'What drives token cost when using Claude through OpenRouter.' },
  { label: 'LLM Observability', href: '/llm-observability/', desc: 'Trace request IDs, token usage and billing signals.' },
];
---

<ArticleShell
  title={page.title}
  metaDescription={page.metaDescription}
  canonical={page.canonical}
  ogTitle={page.ogTitle}
  ogDescription={page.ogDescription}
  breadcrumb={page.breadcrumb}
  category="Agent API"
  h1={page.h1}
  summary="How to set up OpenClaw with OpenRouter, confirm the OpenAI-compatible endpoint, model routing, fallback behavior, API credits and common errors before scaling agent workflows."
  lastReviewed="June 2026"
  readingTime="6 min read"
  trackLabel="Agent API"
>
  <AISummary
    title="OpenClaw with OpenRouter depends on the right base URL, model ID and fallback path."
    summary="Configure the OpenAI-compatible endpoint, verify your OpenRouter API key, check model availability, and separate 401, 403, 404 and 429 failures early. No single step guarantees error-free runs."
  />

  <QuickAnswer steps={quickAnswerSteps} />

  <h2>Who this is for</h2>
  <p>
    Developers using OpenClaw as a coding agent and routing requests through OpenRouter for access to multiple models. If you are comparing routes, choosing a fallback model or checking why one provider path fails while another works, this guide is for you.
  </p>

  <h2>What OpenClaw and OpenRouter do</h2>
  <p>
    OpenClaw is a coding agent that can execute file operations, run shell commands and call model APIs. When configured with OpenRouter, OpenClaw sends requests to the OpenRouter endpoint instead of a single provider.
  </p>
  <p>
    OpenRouter acts as an aggregator API. It provides a single OpenAI-compatible base URL and routes requests to the appropriate underlying provider based on the model ID. OpenRouter manages billing through a credit system, where each model has its own input and output token pricing.
  </p>
  <p>
    The benefit is unified access to many models through one API key and one billing interface. The trade-off is that you need to verify model availability, understand pricing per model, and monitor token usage across the aggregator layer.
  </p>

  <RutaCta />

  <h2>OpenRouter base URL, model ID and routing</h2>
  <p>
    OpenClaw connects to OpenRouter using an OpenAI-compatible endpoint. The key configuration points are:
  </p>
  <ul>
    <li><strong>Base URL:</strong> Set to <code>https://openrouter.ai/api/v1</code> in OpenClaw settings.</li>
    <li><strong>API key:</strong> Your OpenRouter API key, loaded from environment variables or a config file.</li>
    <li><strong>Model ID:</strong> A string from the OpenRouter model catalog, for example <code>anthropic/claude-3-5-sonnet</code> or <code>openai/gpt-4o</code>.</li>
    <li><strong>Routing:</strong> The model ID decides which underlying provider route OpenRouter uses for each request.</li>
  </ul>
  <p>
    Confirm the base URL and API key are set correctly in your OpenClaw configuration file before running any workflows. OpenRouter does not support OpenAI-specific endpoints like assistants or fine-tuning - only chat completions.
  </p>

  <Checklist title="OpenClaw OpenRouter setup checklist" items={checklistItems} />

  <h2>Common errors: 401, 403, 404, 429, no credits, model unavailable</h2>
  <p>
    These are the most common failure modes when OpenClaw is configured with OpenRouter:
  </p>

  <FailureModes modes={failureModes} />

  <h2>Fallback routing and model unavailable responses</h2>
  <p>
    When a model is unavailable, the important question is whether OpenClaw should retry the same route or switch to a fallback model. If the model ID is wrong, a 404-style error usually points to routing or catalog mismatch. If the route exists but the account lacks access, the problem is closer to permissions or balance. Check the exact failure before changing models.
  </p>
  <p>
    Keep a short fallback list with model IDs that are available in the same account tier. That makes it easier to separate routing failures from account-level limits during early tests.
  </p>

  <h2>Why token usage can spike</h2>
  <p>
    Token usage with OpenClaw and OpenRouter can exceed expectations for several reasons:
  </p>
  <ul>
    <li>Each model has its own input and output token pricing on OpenRouter. Switching models changes the cost per token.</li>
    <li>OpenClaw may send full conversation history with each new request, growing the context window across turns.</li>
    <li>Tool calls and file reads generate additional tokens in the prompt and the model response.</li>
    <li>Retries on timeout or rate limit errors resend the full context window, multiplying token consumption.</li>
  </ul>
  <p>
    Review request logs and token counts per call. Use the OpenRouter usage dashboard to compare token counts against your expectations before running long agent sessions.
  </p>

  <h2>Security risks: chat ingress, file permissions, command execution, external tools, prompt injection</h2>
  <p>
    Using OpenClaw with OpenRouter introduces security considerations beyond typical API usage:
  </p>
  <ul>
    <li><strong>Chat ingress:</strong> Conversation history may be logged by the model provider. Do not include sensitive credentials or proprietary code in conversation context unless you have reviewed the provider data policy.</li>
    <li><strong>File permissions:</strong> OpenClaw tool execution can read and write files on the host system. Restrict tool permissions to the minimum required scope.</li>
    <li><strong>Command execution:</strong> Shell commands run through OpenClaw execute on your machine or CI environment. Review each command before allowing execution.</li>
    <li><strong>External tools:</strong> OpenClaw may call external tools or APIs during a workflow. These calls count toward token usage and may expose API keys if not handled carefully.</li>
    <li><strong>Prompt injection:</strong> Malicious user inputs or file contents can influence agent behavior. Sanitize untrusted inputs and review OpenClaw tool outputs before acting on them.</li>
  </ul>

  <h2>Evidence to inspect</h2>
  <EvidenceList items={evidenceItems} />

  <h2>Small prepaid testing checklist</h2>
  <p>
    Before running long agent workflows, test with a small prepaid API balance:
  </p>
  <ul>
    <li>Load a small amount of credits in your OpenRouter account and track usage against the balance.</li>
    <li>Run a short OpenClaw session and compare actual token usage against your cost estimate.</li>
    <li>Review request logs for 401, 403, 429 and 5xx responses during the test run.</li>
    <li>Verify that the model ID in OpenClaw matches a model available in your OpenRouter tier.</li>
    <li>Check the OpenRouter /v1/models endpoint to confirm live model availability before scaling.</li>
  </ul>

  <h2>How RutaAPI fits</h2>
  <p>
    RutaAPI offers prepaid API credits that can be useful when testing OpenClaw workflows and comparing token usage across different model configurations. Test with a small balance before scaling OpenClaw automation. Check live model pricing and verify model availability with the provider before running large workloads. Actual billing depends on token usage and model pricing.
  </p>

  <FAQBlock items={faqItems} />
  <RelatedPages links={relatedLinks} />
</ArticleShell>
