const relatedLinks = [
  { label: 'LLM Observability', href: '/llm-observability/', desc: 'Trace request IDs, token usage and billing signals for media API calls.' },
  { label: 'Claude Code Token Cost', href: '/claude-code-token-cost/', desc: 'Token cost drivers for coding agent workflows.' },
