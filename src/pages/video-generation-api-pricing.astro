import { publicPages } from '../data/pages';

const page = publicPages.find(p => p.slug === 'video-generation-api-pricing')!;

const quickAnswerSteps = [
  'Identify the pricing unit: token, credit, second, image, video or async task.',
  'Determine whether the API uses synchronous or async workflow.',
  'Check if the provider uses polling, webhooks or callbacks for async jobs.',
  'Review timeout, retry and failed generation cost policies.',
  'Test with a small prepaid credit balance before processing batches.',
];

const checklistItems = [
  'Identify the exact pricing unit: token, credit, second, image, video or async task.',
  'Confirm whether the API is synchronous or uses async job creation.',
  'Check if polling interval, webhook endpoint or callback URL is required.',
  'Review timeout duration and what happens when a job times out.',
  'Check whether failed generations and retries count toward billing.',
  'Verify model availability for your region and account tier.',
  'Test with a small prepaid credit balance before processing large batches.',
];

const evidenceItems = [
  { label: 'Provider pricing page', value: 'pricing unit and rate per generation type' },
  { label: 'API documentation', value: 'async workflow, polling interval, webhook format' },
  { label: 'Request logs', value: 'job IDs, status codes, retry attempts' },
  { label: 'Provider dashboard', value: 'credit balance and generation history' },
];

const failureModes = [
  {
    symptom: 'Async job never completes and credit is consumed',
    cause: 'The job timed out on the provider side, but the request already consumed credits. Some providers charge on job creation, not delivery.',
    whatToDo: 'Review the provider timeout policy. Check request logs for the job status. Implement a timeout handler on your side that cancels or flags stuck jobs.',
  },
  {
    symptom: 'Retry loop causes repeated charges for the same failed generation',
    cause: 'Without idempotency checks, a failed generation may be retried multiple times, each attempt consuming credits.',
    whatToDo: 'Store job IDs and check generation status before retrying. Implement exponential backoff with a cap on retry attempts.',
  },
  {
    symptom: 'Polling interval generates unexpected API overhead',
    cause: 'Polling for job status creates additional API calls that may have their own cost. High polling frequency multiplies this overhead.',
    whatToDo: 'Use the longest polling interval that meets your latency requirements. Consider switching to webhooks or callbacks if available, which eliminate polling overhead.',
  },
  {
    symptom: 'Model or region not available at generation time',
    cause: 'Model availability can change. A video generation request may fail because the model is temporarily unavailable in your region.',
    whatToDo: 'Check the /v1/models endpoint or provider documentation for current availability. Implement graceful fallback behavior for unavailable models.',
  },
];

const faqItems = [
  {
    q: 'How is video generation API pricing different from LLM API pricing?',
    a: 'LLM APIs are typically priced per input and output token. Video generation APIs may be priced per credit, per second, per generated video, or per async task — depending on the provider. Some providers also charge for failed generations or retries. Check the provider pricing page carefully.',
  },
  {
    q: 'What is an async video generation workflow?',
    a: 'Many video generation APIs do not return the video directly. Instead, they create an async task and return a job ID. You then poll a status endpoint, receive a webhook callback, or use a callback URL to get the result when the video is ready.',
  },
  {
    q: 'Do failed video generations cost money?',
    a: 'This depends on the provider. Some charge on job creation regardless of outcome. Others only charge on successful delivery. Failed generations and retries should be checked in request logs and provider dashboards. Always review the failed-generation billing policy before processing batches.',
  },
  {
    q: 'What are the risks of polling for video job status?',
    a: 'Polling creates additional API calls that may have their own cost. It also adds latency. If the polling interval is too short, it can trigger rate limits. Consider using webhooks or callbacks instead of polling when the provider supports them.',
  },
  {
    q: 'Does RutaAPI support every video generation model?',
    a: 'No. Model availability can change and varies by provider and region. Check live model pricing and the /v1/models endpoint for currently available video generation models.',
  },
