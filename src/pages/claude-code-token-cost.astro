import { publicPages } from '../data/pages';

const page = publicPages.find(p => p.slug === 'claude-code-token-cost')!;

const quickAnswerSteps = [
  'Review the model pricing for the Claude model you are using.',
  'Check context window size and how much history is sent per request.',
  'Monitor token usage per request and aggregate across the session.',
