const relatedLinks = [
  { label: 'OpenClaw OpenRouter', href: '/openclaw-openrouter/', desc: 'OpenRouter model routing and OpenClaw setup.' },
  { label: 'LLM Observability', href: '/llm-observability/', desc: 'Trace token usage, request IDs and billing signals.' },
