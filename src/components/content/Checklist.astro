---
interface Props {
  title?: string;
  items: string[];
}

const { title, items } = Astro.props;
---

<div class="rounded-xl border border-slate-700/50 bg-surface-card/50 p-5 mb-6">
  <div class="flex items-center gap-2 mb-4">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-slate-400">
      <rect x="2" y="2" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
      <path d="M4.5 5h5M4.5 7h3M4.5 9h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    </svg>
    <span class="text-[10px] font-mono text-slate-400 uppercase tracking-wider">{title || 'Checklist'}</span>
  </div>
  <ul class="space-y-2">
    {items.map(item => (
      <li class="flex items-start gap-2.5">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="text-accent flex-shrink-0 mt-0.5">
          <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="text-xs text-slate-300 leading-relaxed">{item}</span>
      </li>
    ))}
  </ul>
</div>
