---
interface Props {
  title: string;
  summary: string;
}

const { title, summary } = Astro.props;
---

<div class="rounded-xl border border-accent/20 bg-accent/[0.04] p-5 mb-8">
  <div class="flex items-center gap-2 mb-3">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-accent">
      <path d="M7 1L8.5 5.5H13L9.5 8.5L11 13L7 10L3 13L4.5 8.5L1 5.5H5.5L7 1Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
    </svg>
    <span class="text-[10px] font-mono text-accent/70 uppercase tracking-wider">AI Summary</span>
  </div>
  <h3 class="text-sm font-semibold text-white mb-2">{title}</h3>
  <p class="text-xs text-slate-400 leading-relaxed">{summary}</p>
</div>
