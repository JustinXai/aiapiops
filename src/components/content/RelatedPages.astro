---
interface Props {
  links: { label: string; href: string; desc?: string }[];
}

const { links } = Astro.props;
---

<section class="mt-12 border-t border-slate-800/40 pt-10 mb-8">
  <h2 class="text-xl font-bold text-white mb-6">Related guides</h2>
  <div class="grid sm:grid-cols-2 gap-3">
    {links.map(link => (
      <a
        href={link.href}
        class="flex items-start gap-3 p-4 rounded-xl border border-slate-800/60 bg-surface-card/50 hover:bg-surface-card hover:border-slate-700/80 transition-all group"
      >
        <div class="flex-1">
          <p class="text-sm font-medium text-slate-200 group-hover:text-white transition-colors">{link.label}</p>
          {link.desc && (
            <p class="text-xs text-slate-500 mt-1 leading-relaxed">{link.desc}</p>
          )}
        </div>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-slate-600 group-hover:text-slate-400 group-hover:translate-x-0.5 transition-all flex-shrink-0 mt-0.5">
          <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    ))}
  </div>
</section>
