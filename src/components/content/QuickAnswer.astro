---
interface Props {
  steps: string[];
}

const { steps } = Astro.props;
---

<div class="rounded-xl border border-slate-700/50 bg-surface-card p-5 mb-8">
  <div class="flex items-center gap-2 mb-4">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-accent">
      <path d="M2 3h10M2 7h7M2 11h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
    </svg>
    <span class="text-[10px] font-mono text-slate-400 uppercase tracking-wider">Quick Answer</span>
  </div>
  <ol class="space-y-2">
    {steps.map((step, i) => (
      <li class="flex items-start gap-3">
        <span class="flex-shrink-0 w-5 h-5 rounded bg-slate-800 border border-slate-700/50 flex items-center justify-center text-[10px] font-mono text-slate-500">
          {i + 1}
        </span>
        <span class="text-xs text-slate-300 leading-relaxed pt-0.5">{step}</span>
      </li>
    ))}
  </ol>
</div>
