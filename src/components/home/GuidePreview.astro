---
import Card from '../ui/Card.astro';

const checklist = [
  'Check publisher and namespace',
  'Review env variables and API keys',
  'Inspect tool permissions and model routing',
  'Trace tool calls, token usage and media jobs',
];

const relatedGuides = [
  { label: 'MCP for ChatGPT', href: '/mcp-server-chatgpt/' },
  { label: 'OpenClaw OpenRouter', href: '/openclaw-openrouter/' },
  { label: 'Claude Code Token Cost', href: '/claude-code-token-cost/' },
  { label: 'Video Generation API Pricing', href: '/video-generation-api-pricing/' },
  { label: 'LLM Observability', href: '/llm-observability/' },
];
---

<section class="py-20 border-b border-slate-800/40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-start">

      <div>
        <p class="text-accent/70 text-xs font-mono tracking-widest uppercase mb-3">Quick Answer</p>
        <h2 class="text-xl sm:text-2xl font-bold text-white mb-4">
          Agent and media API costs multiply fast.
        </h2>
        <div class="rounded-xl border border-slate-700/50 bg-surface-card p-5 mb-6">
          <p class="text-sm text-slate-300 leading-relaxed mb-5">
            Review API keys, tool permissions, token usage, media job cost units and billing signals together. Agent workflows and async media jobs need active monitoring.
          </p>
          <div class="space-y-2">
            <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-2">Quick Answer checklist</p>
            {checklist.map(item => (
              <div class="flex items-center gap-2">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="text-accent flex-shrink-0">
                  <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-xs text-slate-400">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div>
        <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-4">All guides</p>
        <div class="space-y-2">
          {relatedGuides.map(guide => (
            <a
              href={guide.href}
              class="flex items-center justify-between px-4 py-3 rounded-lg border border-slate-800/60 bg-surface-card/50 hover:bg-surface-card hover:border-slate-700/80 transition-all group"
            >
              <span class="text-sm text-slate-300 group-hover:text-white transition-colors">{guide.label}</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-slate-600 group-hover:text-slate-400 group-hover:translate-x-0.5 transition-all">
                <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
