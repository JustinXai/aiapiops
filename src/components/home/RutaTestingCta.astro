---
import { ctaButtons } from '../../data/nav';
---

<section class="py-20 border-b border-slate-800/40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Test small before long agent runs.</h2>
      <p class="text-sm text-slate-400 mb-8 leading-relaxed">
        Before scaling MCP tools or agent workflows, check model availability and cost assumptions with a small prepaid API balance.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={ctaButtons.primary.href}
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent/10 border border-accent/50 text-accent font-semibold text-sm rounded-lg hover:bg-accent/20 hover:border-accent/70 transition-all hover:glow-accent-sm"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1L7 13M1 7L13 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          {ctaButtons.primary.text}
        </a>
        <a
          href={ctaButtons.secondary.href}
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-surface-card border border-slate-700/60 text-slate-300 font-medium text-sm rounded-lg hover:border-slate-600/80 hover:text-white hover:bg-surface-card/80 transition-all"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {ctaButtons.secondary.text}
        </a>
      </div>
    </div>
  </div>
</section>
