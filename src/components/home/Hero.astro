---
import TerminalWindow from '../ui/TerminalWindow.astro';
import { ctaButtons } from '../../data/nav';

const terminalLines = [
  '$ inspect --server chatgpt-mcp --scope tools',
  'ok    manifest found · tools exposed: 6',
  'warn  API key passed via environment variable',
  'check tool calls may trigger paid API usage',
];
---

<section class="relative border-b border-slate-800/40 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <div class="space-y-8">
        <div>
          <p class="text-accent/70 text-xs font-mono tracking-widest uppercase mb-4">AI API Ops</p>
          <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold text-white leading-[1.1] tracking-tight">
            Run AI apps with fewer API surprises.
          </h1>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={ctaButtons.primary.href}
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent/10 border border-accent/50 text-accent font-semibold text-sm rounded-lg hover:bg-accent/20 hover:border-accent/70 transition-all hover:glow-accent-sm"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="flex-shrink-0">
              <path d="M7 1L7 13M1 7L13 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            {ctaButtons.primary.text}
          </a>
          <a
            href={ctaButtons.secondary.href}
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-surface-card border border-slate-700/60 text-slate-300 font-medium text-sm rounded-lg hover:border-slate-600/80 hover:text-white hover:bg-surface-card/80 transition-all"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="flex-shrink-0">
              <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {ctaButtons.secondary.text}
          </a>
        </div>
      </div>

      <div class="space-y-4">
        <div class="rounded-xl border border-accent/20 bg-surface-card p-4 space-y-3">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-2 h-2 rounded-full bg-accent/60"></div>
            <span class="text-xs font-mono text-slate-500">ops snapshot</span>
          </div>
          <div class="font-mono text-xs text-slate-300 space-y-1">
            <div class="flex items-center gap-2">
              <span class="text-accent/70">MCP</span>
              <span class="text-slate-600">&rarr;</span>
              <span class="text-slate-400">tools</span>
              <span class="text-slate-600">&rarr;</span>
              <span class="text-slate-400">usage</span>
            </div>
          </div>
          <p class="text-[11px] text-slate-500 leading-relaxed">
            Check trust, secrets, tool calls and billing signals before long agent runs.
          </p>
        </div>

        <TerminalWindow lines={terminalLines} title="inspect --server chatgpt-mcp" />
      </div>

    </div>
  </div>

  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-accent/[0.02] via-transparent to-transparent pointer-events-none"></div>
</section>
