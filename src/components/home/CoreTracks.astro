---
import Card from '../ui/Card.astro';

const tracks = [
  {
    title: 'MCP for ChatGPT Apps',
    description: 'Review server trust, tool exposure, API key handling and cost signals before connecting workflows.',
    href: '/mcp-server-chatgpt/',
    badge: 'Guide',
    highlight: true,
  },
  {
    title: 'OpenClaw OpenRouter',
    description: 'Configure the OpenAI-compatible endpoint, API credits, model routing, 401 and 403 errors.',
    href: '/openclaw-openrouter/',
    badge: 'Guide',
    highlight: false,
  },
  {
    title: 'Claude Code Token Cost',
    description: 'What drives Claude Code token cost, context management, tool calls and automation patterns.',
    href: '/claude-code-token-cost/',
    badge: 'Guide',
    highlight: false,
  },
  {
    title: 'Video Generation API Pricing',
    description: 'Pricing units, async workflows, polling, webhooks, failed generation and retry cost.',
    href: '/video-generation-api-pricing/',
    badge: 'Guide',
    highlight: false,
  },
  {
    title: 'API Credits & Billing',
    description: 'Understand OpenAI-compatible API usage, prepaid credits, billing records and small-balance testing.',
    href: null,
    badge: 'Planned',
    highlight: false,
  },
  {
    title: 'LLM Observability',
    description: 'Trace model calls, tool calls, retries, latency and billing deltas before scaling agents.',
    href: '/llm-observability/',
    badge: 'Guide',
    highlight: false,
  },
];
---

<section class="py-20 border-b border-slate-800/40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">From MCP trust to billing evidence.</h2>
      <p class="text-sm text-slate-400 max-w-2xl">
        Each guide covers what to check, what can go wrong, and when to test with a small prepaid balance.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tracks.map((track) => (
        <Card
          title={track.title}
          description={track.description}
          href={track.href}
          badge={track.badge}
          highlight={track.highlight}
        />
      ))}
    </div>
  </div>
</section>
