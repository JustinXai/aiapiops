---
interface Props {
  text: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
}

const { text, href, variant = 'primary' } = Astro.props;

const variantClasses = {
  primary: 'bg-accent/10 border border-accent/40 text-accent hover:bg-accent/20 hover:border-accent/60 hover:glow-accent-sm',
  secondary: 'bg-surface-card border border-slate-700/60 text-slate-300 hover:border-slate-600/80 hover:text-white hover:bg-surface-card/80',
  ghost: 'text-slate-400 hover:text-slate-200 hover:bg-white/5',
};
---

<a
  href={href}
  class={`inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-150 ${variantClasses[variant]}`}
>
  <slot name="icon" />
  {text}
</a>
