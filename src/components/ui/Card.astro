---
interface Props {
  title: string;
  description?: string;
  href?: string;
  badge?: string;
  highlight?: boolean;
}

const { title, description, href, badge, highlight = false } = Astro.props;
---

{href ? (
  <a
    href={href}
    class={`group block rounded-xl border p-5 transition-all duration-200 ${
      highlight
        ? 'border-accent/40 bg-surface-card hover:border-accent/60 hover:glow-accent-sm'
        : 'border-slate-800/60 bg-surface-card hover:border-slate-700/80 hover:bg-surface-card/80'
    }`}
  >
    <div class="flex items-start justify-between gap-3">
      <h3 class={`font-semibold text-sm leading-snug ${highlight ? 'text-accent' : 'text-slate-200 group-hover:text-white'}`}>
        {title}
      </h3>
      {badge && (
        <span class="flex-shrink-0 text-[10px] font-mono px-1.5 py-0.5 rounded bg-slate-800 text-slate-500 border border-slate-700/50">
          {badge}
        </span>
      )}
    </div>
    {description && (
      <p class="mt-2 text-xs text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors">
        {description}
      </p>
    )}
  </a>
) : (
  <div class={`rounded-xl border p-5 ${highlight ? 'border-accent/20 bg-surface-card/50' : 'border-slate-800/60 bg-surface-card/50'}`}>
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-semibold text-sm text-slate-400">{title}</h3>
      {badge && (
        <span class="flex-shrink-0 text-[10px] font-mono px-1.5 py-0.5 rounded bg-slate-800 text-slate-600 border border-slate-700/50">
          {badge}
        </span>
      )}
    </div>
    {description && (
      <p class="mt-2 text-xs text-slate-500 leading-relaxed">
        {description}
      </p>
    )}
  </div>
)}
